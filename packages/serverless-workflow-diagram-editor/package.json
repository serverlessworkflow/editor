{
  "name": "serverless-workflow-diagram-editor",
  "version": "1.0.0",
  "description": "React serverless workflow diagram component",
  "license": "Apache-2.0",
  "keywords": [],
  "homepage": "https://github.com/serverlessworkflow/editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/serverlessworkflow/editor.git"
  },
  "bugs": {
    "url": "https://github.com/serverlessworkflow/editor/issues"
  },
  "packageManager": "pnpm@10.31.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint ./",
    "lint:fix": "eslint ./ --fix",
    "clean": "rimraf ./dist",
    "clean:storybook": "rimraf ./dist-storybook",
    "build:dev": "pnpm clean && tsc -p tsconfig.json",
    "build:prod": "pnpm lint && pnpm clean && tsc -p tsconfig.json && pnpm test",
    "test": "vitest run --passWithNoTests",
    "start": "storybook dev -p 6006 --no-open",
    "build:storybook": "pnpm clean:storybook && storybook build --output-dir ./dist-storybook"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-flow": "^7.27.1",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@chromatic-com/storybook": "^5.0.1",
    "@serverless-workflow-settings/eslint-config": "workspace:*",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-vitest": "^10.2.19",
    "@storybook/react-vite": "^10.2.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-webdriverio": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "eslint-plugin-storybook": "^10.2.16",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "jsdom": "^25.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "storybook": "^10.2.19",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
