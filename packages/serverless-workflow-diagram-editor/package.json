{
  "name": "serverless-workflow-diagram-editor",
  "version": "1.0.0",
  "description": "React serverless workflow diagram component",
  "keywords": [],
  "homepage": "https://github.com/serverlessworkflow/editor",
  "bugs": {
    "url": "https://github.com/serverlessworkflow/editor/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/serverlessworkflow/editor.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "linter src/ stories/",
    "clean": "rimraf ./dist",
    "clean:storybook": "rimraf ./dist-storybook",
    "build:dev": "pnpm clean && tsc -p tsconfig.json",
    "build:prod": "pnpm lint && pnpm clean && tsc -p tsconfig.json && pnpm test",
    "test": "vitest run --passWithNoTests",
    "start": "storybook dev -p 6006 --no-open",
    "build:storybook": "pnpm clean:storybook && storybook build --output-dir ./dist-storybook"
  },
  "devDependencies": {
    "@babel/cli": "catalog:",
    "@babel/core": "catalog:",
    "@babel/preset-env": "catalog:",
    "@babel/preset-flow": "catalog:",
    "@babel/preset-react": "catalog:",
    "@babel/preset-typescript": "catalog:",
    "@chromatic-com/storybook": "catalog:",
    "@serverless-workflow-settings/linter": "workspace:*",
    "@storybook/addon-a11y": "catalog:",
    "@storybook/addon-docs": "catalog:",
    "@storybook/addon-vitest": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/browser-webdriverio": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint-plugin-storybook": "catalog:",
    "globals": "catalog:",
    "jiti": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "catalog:",
    "storybook": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "packageManager": "pnpm@10.31.0"
}
