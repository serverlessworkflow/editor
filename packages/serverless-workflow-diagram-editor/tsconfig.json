{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": false,
    "emitDeclarationOnly": true,
    "noEmitOnError": true,
    "rootDirs": ["./src", "./tests"],
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "dist-storybook"]
}
